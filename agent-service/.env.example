# Copy to .env and fill in your keys.
# Both keys are used by the ingestion script and by n8n (via n8n credentials).
# Do not commit .env.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# n8n API key (for importing workflows programmatically).
N8N_API_KEY=
N8N_URL=http://localhost:5678

# Qdrant (defaults work for local docker-compose).
QDRANT_URL=http://qdrant:6333
COLLECTION_NAME=cdpi_corpus
