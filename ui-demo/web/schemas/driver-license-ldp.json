{
  "id": "driver-license-ldp",
  "name": "Driver's License (LDP_VC)",
  "description": "W3C Verifiable Credential for driving privileges. For ISO 18013-5 mDL format, use the mDoc variant instead.",
  "category": "transport",
  "credentialType": "DriverLicense",
  "format": "ldp_vc",
  "standard": "W3C-VCDM 1.1",
  "compatibleDPGs": ["waltid", "inji"],
  "fields": [
    {"name": "holderName", "type": "string", "required": true},
    {"name": "licenseNumber", "type": "string", "required": true},
    {"name": "dateOfBirth", "type": "date", "required": true},
    {"name": "issueDate", "type": "date", "required": true},
    {"name": "expiryDate", "type": "date", "required": true},
    {"name": "vehicleClasses", "type": "string", "required": true},
    {"name": "issuingAuthority", "type": "string", "required": true}
  ]
}
