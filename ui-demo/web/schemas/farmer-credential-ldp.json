{
  "id": "farmer-credential-ldp",
  "name": "Farmer Credential (LDP_VC)",
  "description": "Farmer registration / subsidy entitlement credential aligned with the MOSIP FarmerCredentialV2 template.",
  "category": "agriculture",
  "credentialType": "FarmerCredential",
  "format": "ldp_vc",
  "standard": "W3C-VCDM 2.0",
  "compatibleDPGs": ["waltid", "inji"],
  "fields": [
    {"name": "fullName", "type": "string", "required": true},
    {"name": "farmerID", "type": "string", "required": true},
    {"name": "dateOfBirth", "type": "date", "required": true},
    {"name": "gender", "type": "string", "required": false},
    {"name": "mobileNumber", "type": "string", "required": false},
    {"name": "district", "type": "string", "required": true},
    {"name": "villageOrTown", "type": "string", "required": false},
    {"name": "landArea", "type": "number", "required": false},
    {"name": "primaryCropType", "type": "string", "required": false}
  ]
}
