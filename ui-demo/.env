# VC Platform Environment Configuration
# These values are used by docker-compose, init scripts, and the Go app.

# App
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# Walt.id DPG Stack
WALTID_ISSUER_PORT=7002
WALTID_VERIFIER_PORT=7003
WALTID_WALLET_PORT=7001

# Caddy reverse proxy (must match Walt.id ports)
WALLET_BACKEND_PORT=7001
ISSUER_API_PORT=7002
VERIFIER_API_PORT=7003
WALTID_ISSUER_URL=http://localhost:7002
WALTID_VERIFIER_URL=http://localhost:7003
WALTID_WALLET_URL=http://localhost:7001

# Keycloak
KEYCLOAK_PORT=8180
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=vcplatform
KEYCLOAK_CLIENT_ID=vcplatform
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# WSO2 Identity Server
WSO2_PORT=9443
WSO2_URL=https://localhost:9443
WSO2_APP_NAME=vcplatform
WSO2_ADMIN_USER=admin
WSO2_ADMIN_PASSWORD=admin
WSO2_CLIENT_ID_FILE=/tmp/wso2-client-id

# Postgres (for Walt.id wallet)
POSTGRES_DB=waltid
POSTGRES_USER=waltid
POSTGRES_PASSWORD=waltid
POSTGRES_PORT=5432

# TLS
WSO2_CA_CERT_PATH=docker/waltid/wso2-certs/wso2.pem

# Translation
DEEPL_API_KEY=
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_PORT=5000
